NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://astir:astir@localhost:5432/astir?schema=public
FRONTEND_ORIGIN=http://localhost:5173
API_TARGET=http://localhost:3000

# Google OAuth (see docs/google-oauth-setup.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback

# Session signing secret. Any long random string; generate with: openssl rand -hex 32
JWT_SECRET=dev-only-jwt-secret

# Hourly job-board polling: ATS boards (Greenhouse/Ashby/Workable/Lever/
# SmartRecruiters/Recruitee/Teamtailor) plus aggregator feeds (Arbeitnow/The Muse).
# Set to false to turn it off.
JOB_INGESTION_ENABLED=true

# Adzuna aggregator (optional). Free personal-use key from developer.adzuna.com;
# leave blank to keep the feed off. NOTE: the free tier is personal use only —
# commercial use requires a licence from Adzuna. The public job board must show
# a "Jobs by Adzuna" attribution wherever these listings appear.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
